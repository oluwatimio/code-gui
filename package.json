{
  "name": "code-gui",
  "version": "1.1.1",
  "description": "Beautiful desktop GUI for Claude Code CLI (macOS, Linux, Windows)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node --test tests/*.test.js",
    "build": "electron-builder --linux pacman AppImage",
    "build:appimage": "electron-builder --linux AppImage",
    "build:pacman": "electron-builder --linux pacman",
    "build:mac": "electron-builder --mac",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "author": {
    "name": "timi",
    "email": "timi@localhost"
  },
  "homepage": "https://github.com/oluwatimio/code-gui",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "diff": "^9.0.0",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.4",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.claude-code-gui.app",
    "productName": "Code GUI",
    "linux": {
      "target": [
        "pacman",
        "AppImage"
      ],
      "icon": "assets/icons/",
      "category": "Development",
      "synopsis": "Beautiful GUI for Claude Code CLI",
      "desktop": {
        "entry": {
          "Name": "Code GUI",
          "Comment": "Beautiful GUI for Claude Code CLI",
          "Terminal": "false",
          "Type": "Application",
          "Categories": "Development;Utility;"
        }
      }
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "extraResources": [
      {
        "from": "mcp-permission-server.js",
        "to": "mcp-permission-server.js"
      },
      {
        "from": "mcp-context-server.js",
        "to": "mcp-context-server.js"
      },
      {
        "from": "mcp-ask-server.js",
        "to": "mcp-ask-server.js"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ]
  }
}
