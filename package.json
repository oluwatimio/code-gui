{
  "name": "claude-code-gui",
  "version": "1.0.0",
  "description": "Beautiful GUI for Claude Code CLI on Linux",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --linux pacman AppImage",
    "build:appimage": "electron-builder --linux AppImage",
    "build:pacman": "electron-builder --linux pacman"
  },
  "author": {
    "name": "timi",
    "email": "timi@localhost"
  },
  "homepage": "https://github.com/timi/claude-code-gui",
  "license": "MIT",
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^17.0.4"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.claude-code-gui.app",
    "productName": "Claude Code",
    "linux": {
      "target": [
        "pacman",
        "AppImage"
      ],
      "icon": "assets/icons/",
      "category": "Development",
      "synopsis": "Beautiful GUI for Claude Code CLI",
      "desktop": {
        "entry": {
          "Name": "Claude Code",
          "Comment": "Beautiful GUI for Claude Code CLI",
          "Terminal": "false",
          "Type": "Application",
          "Categories": "Development;Utility;"
        }
      }
    },
    "extraResources": [
      {
        "from": "mcp-permission-server.js",
        "to": "mcp-permission-server.js"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "asar": true
  }
}
